{
  "private": true,
  "scripts": {
    "lefthook": "node ./apps/mobile/node_modules/lefthook/bin/index.js",
    "hooks:install": "yarn lefthook install",
    "api:build": "npm --prefix ./services/api run build",
    "api:migrate": "npm --prefix ./services/api run migrate",
    "api:seed:admin": "npm --prefix ./services/api run seed:admin",
    "api:setup:local": "npm --prefix ./services/api run migrate && npm --prefix ./services/api run seed:admin",
    "admin:build": "npm --prefix ./admin/web run build",
    "mobile:lint": "yarn --cwd ./apps/mobile lint",
    "mobile:typecheck": "yarn --cwd ./apps/mobile typecheck",
    "docker:config": "bash ./scripts/docker-validate.sh",
    "docker:local:up": "docker compose --env-file .env.development -f docker-compose.local.yml up --build",
    "docker:local:up:mobile-web": "docker compose --env-file .env.development -f docker-compose.local.yml --profile mobile-web up --build",
    "docker:local:up:mobile-native": "docker compose --env-file .env.development -f docker-compose.local.yml --profile mobile-native up --build",
    "docker:local:down": "docker compose --env-file .env.development -f docker-compose.local.yml down",
    "docker:local:logs": "docker compose --env-file .env.development -f docker-compose.local.yml logs -f",
    "docker:prod:config": "docker compose --env-file .env.production -f docker-compose.production.yml config",
    "docker:prod:up": "docker compose --env-file .env.production -f docker-compose.production.yml up -d --build",
    "docker:prod:down": "docker compose --env-file .env.production -f docker-compose.production.yml down",
    "docker:prod:logs": "docker compose --env-file .env.production -f docker-compose.production.yml logs -f",
    "review:all": "bash ./scripts/review-all.sh",
    "precommit:check": "bash ./scripts/precommit-all-staged.sh",
    "prepush:check": "bash ./scripts/prepush-all-checks.sh"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/node": "^25.3.0"
  }
}
