{
  "name": "claudy-admin-api",
  "version": "1.0.0",
  "description": "Enterprise-ready admin backend for Claudy mobile platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "migrate": "ts-node-dev --exit-child --transpile-only src/db/migrate.ts",
    "migrate:prod": "node dist/db/migrate.js",
    "migrate:status": "ts-node-dev --exit-child --transpile-only src/db/migrationStatus.ts",
    "migrate:status:prod": "node dist/db/migrationStatus.js",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@supabase/supabase-js": "^2.56.0",
    "@types/compression": "^1.8.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.63.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^8.0.0",
    "ioredis": "^5.8.1",
    "jose": "^4.15.9",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^7.0.11",
    "otplib": "^13.4.1",
    "pg": "^8.16.3",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "winston": "^3.11.0",
    "ws": "^8.18.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.9.0",
    "@types/jest": "^29.5.14",
    "@types/pg": "^8.15.6",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "~5.9.2"
  }
}
