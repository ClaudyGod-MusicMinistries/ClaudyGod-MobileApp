# Runtime
NODE_ENV=production
CLAUDYGOD_ENV=production
API_HOST=0.0.0.0
API_PORT=4000
ADMIN_DOMAIN=admin.your-domain.com
API_DOMAIN=api.your-domain.com
APP_DOMAIN=app.your-domain.com
TRAEFIK_PUBLIC_NETWORK=traefik-public
TRAEFIK_CERT_RESOLVER=letsencrypt

# Supabase PostgreSQL
DATABASE_URL=postgresql://postgres.your-project-ref:your-supabase-db-password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&prefer_simple_protocol=true
DATABASE_SSL=true
REDIS_URL=redis://redis:6379

# Security and auth
JWT_ACCESS_SECRET=generate-64-plus-random-characters-for-access-token-signing
JWT_ACCESS_TTL=5m
JWT_REFRESH_SECRET=generate-a-different-64-plus-random-character-refresh-secret
JWT_REFRESH_TTL_DAYS=30
BCRYPT_ROUNDS=12
MOBILE_API_KEY=generate-a-strong-mobile-api-key-and-match-it-in-expo-public-env
AUTH_PUBLIC_BASE_URL=https://app.your-domain.com
AUTH_VERIFY_EMAIL_PATH=/verify-email
AUTH_RESET_PASSWORD_PATH=/reset-password
AUTH_SIGN_IN_PATH=/sign-in
AUTH_ACCOUNT_REVIEW_PATH=/settings/account
AUTH_SESSION_COOKIE_NAME=claudygod_session
AUTH_REFRESH_COOKIE_NAME=claudygod_refresh_session
AUTH_VERIFICATION_TOKEN_TTL_MINUTES=1440
AUTH_PASSWORD_RESET_TOKEN_TTL_MINUTES=30
AUTH_REQUIRE_EMAIL_VERIFICATION=true
CORS_ORIGIN=https://admin.your-domain.com,https://app.your-domain.com

# Admin web
VITE_API_URL=https://api.your-domain.com
VITE_GOOGLE_LOGIN_URL=
VITE_MOBILE_PREVIEW_URL=https://app.your-domain.com

# Mobile app
EXPO_ACCOUNT_OWNER=your-expo-account-or-org
EXPO_PUBLIC_API_URL=https://api.your-domain.com
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable__your_supabase_publishable_key
EXPO_PUBLIC_MOBILE_API_KEY=must-match-mobile-api-key-above
EAS_PROJECT_ID=00000000-0000-0000-0000-000000000000
EXPO_PUBLIC_EAS_PROJECT_ID=00000000-0000-0000-0000-000000000000

# Supabase privileged services and Google sign-in
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=mobile-uploads
# Configure Google as a Supabase Auth provider and allow these redirect URLs:
# claudygod://auth/callback, exp://*/--/auth/callback, https://app.your-domain.com/auth/callback

# Email
EMAIL_BRAND_NAME=ClaudyGod
EMAIL_LOGO_URL=
EMAIL_SUPPORT_EMAIL=support@your-domain.com
EMAIL_SUPPORT_URL=https://your-domain.com/support
EMAIL_FACEBOOK_URL=https://facebook.com/your-page
EMAIL_X_URL=https://x.com/your-profile
EMAIL_INSTAGRAM_URL=https://instagram.com/your-profile
EMAIL_YOUTUBE_URL=https://youtube.com/@YourChannel
MAIL_FROM="ClaudyGod <support@your-domain.com>"
MAIL_REPLY_TO=support@your-domain.com
ADMIN_ALERT_EMAILS=ops@your-domain.com,admin@your-domain.com
SMTP_PROVIDER=brevo
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_POOL=true
SMTP_MAX_CONNECTIONS=5
SMTP_MAX_MESSAGES=200
SMTP_CONNECTION_TIMEOUT_MS=30000
SMTP_GREETING_TIMEOUT_MS=30000
SMTP_REQUIRE_TLS=true
SMTP_TLS_REJECT_UNAUTHORIZED=true
POSTFIX_MYHOSTNAME=mail.example.com
POSTFIX_RELAY_HOST=smtp-relay.brevo.com
POSTFIX_RELAY_PORT=587
POSTFIX_SMTP_USERNAME=your-brevo-smtp-username
POSTFIX_SMTP_PASSWORD=your-brevo-smtp-password

# YouTube
YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_CHANNEL_ID=https://www.youtube.com/@YourChannel
YOUTUBE_MAX_RESULTS=12

# Admin access
ADMIN_SIGNUP_CODE=generate-a-private-admin-invitation-code
