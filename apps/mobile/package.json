{
  "name": "claudygod-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --clear",
    "start": "cross-env EXPO_NO_DOCTOR=1 EXPO_NO_DEPENDENCY_VALIDATION=1 EXPO_OFFLINE=1 expo start --offline",
    "start:offline": "cross-env EXPO_NO_DOCTOR=1 EXPO_NO_DEPENDENCY_VALIDATION=1 EXPO_OFFLINE=1 expo start --offline",
    "start:clear": "cross-env EXPO_NO_DOCTOR=1 EXPO_NO_DEPENDENCY_VALIDATION=1 EXPO_OFFLINE=1 expo start --offline -c",
    "start:offline:clear": "cross-env EXPO_NO_DOCTOR=1 EXPO_NO_DEPENDENCY_VALIDATION=1 EXPO_OFFLINE=1 expo start --offline -c",
    "start:online": "cross-env EXPO_NO_DOCTOR=1 EXPO_NO_DEPENDENCY_VALIDATION=1 expo start",
    "start:online:clear": "cross-env EXPO_NO_DOCTOR=1 EXPO_NO_DEPENDENCY_VALIDATION=1 expo start -c",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "check": "node ./scripts/check-all.js",
    "check:deps": "node ./scripts/check-dependencies.js",
    "check:pre-commit": "node ./scripts/check-dependencies.js && lint-staged",
    "check:pre-push": "node ./scripts/check-all.js",
    "test": "jest",
    "hooks:install": "lefthook install",
    "postinstall": "node ./scripts/postinstall.js"
  },
  "dependencies": {
    "@babel/runtime": "^7.25.0",
    "@tanstack/react-query": "^5.101.2",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo/metro-runtime": "^6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@shopify/flash-list": "2.0.2",
    "@supabase/supabase-js": "^2.80.0",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-audio": "~1.1.1",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "expo-video": "~3.0.15",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-responsive-screen": "^1.4.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "babel-preset-expo": "~54.0.10",
    "@types/react": "~19.1.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "cross-env": "^10.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "jest-expo": "~54.0.17",
    "lefthook": "^1.7.15",
    "lint-staged": "^15.2.10",
    "sharp": "^0.35.2",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --cache --fix --max-warnings=0"
    ]
  },
  "private": true
}
